PORT=3001
NODE_ENV=development

# Generate with: openssl rand -hex 64
JWT_SECRET=

# Frontend URL (for email links)
CLIENT_URL=http://localhost:5173

# Email provider (Resend recommended for production)
RESEND_API_KEY=
EMAIL_FROM=FamilySync <noreply@yourdomain.com>

# Legacy Gmail support (development only)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# PostgreSQL (production)
DATABASE_URL=postgresql://user:password@localhost:5432/familysync

# Sentry (error tracking)
SENTRY_DSN=
